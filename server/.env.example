# Server Configuration
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/dsa-hub

# Security & Secrets (Rotate these regularly!)
JWT_SECRET=your_jwt_secret_phrase_here
REFRESH_SECRET=your_refresh_secret_phrase_here
COOKIE_SECRET=your_cookie_signing_secret_here
SESSION_SECRET=your_express_session_secret_here
API_KEY=your_dummy_api_key_check_with_frontend

# Admin Access
ADMIN_PASSWORD=your_admin_dashboard_password
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# Authentication Providers
# GitHub
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# CORS - Comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-production-app.com

